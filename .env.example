# WashTime Backend - Environment Configuration Template

# Render PostgreSQL Database
# Get this from: Render Dashboard → PostgreSQL → Copy "External Database URL"
DATABASE_URL=your-render-database-url-here

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret for Authentication
# IMPORTANT: Change this to a random string in production!
JWT_SECRET=your_jwt_secret_key_change_this_in_production

# =============================================================================
# SETUP INSTRUCTIONS:
# =============================================================================
# 1. Create Render account at https://render.com/
# 2. Create PostgreSQL database (New → PostgreSQL)
# 3. Copy "External Database URL" from Render
# 4. Rename this file from .env.example to .env
# 5. Paste your Render DATABASE_URL above
# 6. Run: npm install
# 7. Run: npm run init-db
# 8. Run: npm run dev
# =============================================================================
